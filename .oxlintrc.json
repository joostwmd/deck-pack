{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["external/**"],
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "typescript/no-floating-promises": ["error", { "ignoreVoid": true }]
  },
  "settings": {
    "react": {
      "version": "19.0"
    }
  },
  "env": {
    "builtin": true
  },
  "overrides": [
    {
      "files": ["apps/api/src/domains/**/routes.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": ["drizzle-orm", "@deck-pack/db"]
          }
        ]
      }
    },
    {
      "files": ["apps/api/src/domains/**/service.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": ["@trpc/server"]
          }
        ]
      }
    },
    {
      "files": [
        "apps/*/src/components/**/*.{ts,tsx}",
        "apps/*/src/hooks/**/*.{ts,tsx}",
        "apps/*/src/lib/**/*.{ts,tsx}",
        "apps/*/src/features/**/*.{ts,tsx}"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": ["@/utils/trpc", "@/utils/auth"]
          }
        ]
      }
    },
    {
      "files": ["apps/*/src/**/*-view.tsx"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": ["@/services"]
          }
        ]
      }
    },
    {
      "files": [
        "apps/addins/assets/src/lib/**/*.{ts,tsx}",
        "apps/addins/assets/src/hooks/**/*.{ts,tsx}",
        "apps/addins/assets/src/features/**/*.{ts,tsx}",
        "apps/addins/assets/src/components/**/*.{ts,tsx}"
      ],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "paths": [
              {
                "name": "@deck-pack/office-js",
                "importNames": ["officeClient"]
              }
            ]
          }
        ]
      }
    },
    {
      "files": [
        "apps/portal/**/*.{ts,tsx,js,jsx}",
        "apps/ops/**/*.{ts,tsx,js,jsx}",
        "apps/addins/**/*.{ts,tsx,js,jsx}",
        "packages/ui/**/*.{ts,tsx,js,jsx}"
      ],
      "env": {
        "builtin": true,
        "browser": true
      },
      "plugins": ["typescript", "unicorn", "oxc", "react"],
      "jsPlugins": ["eslint-plugin-react-you-might-not-need-an-effect"],
      "rules": {
        "react-you-might-not-need-an-effect/no-derived-state": "error",
        "react-you-might-not-need-an-effect/no-chain-state-updates": "error",
        "react-you-might-not-need-an-effect/no-event-handler": "error",
        "react-you-might-not-need-an-effect/no-adjust-state-on-prop-change": "error",
        "react-you-might-not-need-an-effect/no-reset-all-state-on-prop-change": "error",
        "react-you-might-not-need-an-effect/no-pass-live-state-to-parent": "error",
        "react-you-might-not-need-an-effect/no-pass-data-to-parent": "error",
        "react-you-might-not-need-an-effect/no-initialize-state": "error",
        "react-you-might-not-need-an-effect/no-empty-effect": "error",
        "react/exhaustive-deps": "error"
      }
    }
  ]
}
