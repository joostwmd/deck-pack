{
  "name": "deck-pack",
  "private": true,
  "workspaces": [
    "apps/*",
    "apps/addins/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:api": "turbo -F @deck-pack/api build",
    "build:ops": "turbo -F @deck-pack/ops build",
    "auth:generate": "turbo -F @deck-pack/auth auth:generate",
    "tf:init:shared:foundation": "terraform -chdir=terraform/envs/shared/foundation init",
    "tf:plan:shared:foundation": "terraform -chdir=terraform/envs/shared/foundation plan",
    "tf:apply:shared:foundation": "terraform -chdir=terraform/envs/shared/foundation apply",
    "tf:init:shared:ci-identity": "terraform -chdir=terraform/envs/shared/ci-identity init",
    "tf:plan:shared:ci-identity": "terraform -chdir=terraform/envs/shared/ci-identity plan",
    "tf:apply:shared:ci-identity": "terraform -chdir=terraform/envs/shared/ci-identity apply",
    "tf:init:shared:github-governance": "terraform -chdir=terraform/envs/shared/github-governance init",
    "tf:plan:shared:github-governance": "terraform -chdir=terraform/envs/shared/github-governance plan",
    "tf:apply:shared:github-governance": "terraform -chdir=terraform/envs/shared/github-governance apply",
    "tf:init:prod:database": "terraform -chdir=terraform/envs/prod/database init",
    "tf:plan:prod:database": "terraform -chdir=terraform/envs/prod/database plan",
    "tf:apply:prod:database": "terraform -chdir=terraform/envs/prod/database apply",
    "tf:init:prod:key-vault": "terraform -chdir=terraform/envs/prod/key-vault init",
    "tf:plan:prod:key-vault": "terraform -chdir=terraform/envs/prod/key-vault plan",
    "tf:apply:prod:key-vault": "terraform -chdir=terraform/envs/prod/key-vault apply",
    "tf:init:prod:static-web-apps": "terraform -chdir=terraform/envs/prod/static-web-apps init",
    "tf:plan:prod:static-web-apps": "terraform -chdir=terraform/envs/prod/static-web-apps plan",
    "tf:apply:prod:static-web-apps": "terraform -chdir=terraform/envs/prod/static-web-apps apply",
    "tf:init:prod:storage": "terraform -chdir=terraform/envs/prod/storage init",
    "tf:plan:prod:storage": "terraform -chdir=terraform/envs/prod/storage plan",
    "tf:apply:prod:storage": "terraform -chdir=terraform/envs/prod/storage apply",
    "tf:init:prod:app-service": "terraform -chdir=terraform/envs/prod/app-service init",
    "tf:plan:prod:app-service": "terraform -chdir=terraform/envs/prod/app-service plan",
    "tf:apply:prod:app-service": "terraform -chdir=terraform/envs/prod/app-service apply",
    "tf:apply:prod:app-service:auto": "terraform -chdir=terraform/envs/prod/app-service apply -auto-approve",
    "tf:init:prod:front-door": "terraform -chdir=terraform/envs/prod/front-door init",
    "tf:plan:prod:front-door": "terraform -chdir=terraform/envs/prod/front-door plan",
    "tf:apply:prod:front-door": "terraform -chdir=terraform/envs/prod/front-door apply",
    "tf:init:staging:database": "terraform -chdir=terraform/envs/staging/database init",
    "tf:plan:staging:database": "terraform -chdir=terraform/envs/staging/database plan",
    "tf:apply:staging:database": "terraform -chdir=terraform/envs/staging/database apply",
    "tf:init:staging:key-vault": "terraform -chdir=terraform/envs/staging/key-vault init",
    "tf:plan:staging:key-vault": "terraform -chdir=terraform/envs/staging/key-vault plan",
    "tf:apply:staging:key-vault": "terraform -chdir=terraform/envs/staging/key-vault apply",
    "tf:init:staging:static-web-apps": "terraform -chdir=terraform/envs/staging/static-web-apps init",
    "tf:plan:staging:static-web-apps": "terraform -chdir=terraform/envs/staging/static-web-apps plan",
    "tf:apply:staging:static-web-apps": "terraform -chdir=terraform/envs/staging/static-web-apps apply",
    "tf:init:staging:storage": "terraform -chdir=terraform/envs/staging/storage init",
    "tf:plan:staging:storage": "terraform -chdir=terraform/envs/staging/storage plan",
    "tf:apply:staging:storage": "terraform -chdir=terraform/envs/staging/storage apply",
    "tf:init:staging:app-service": "terraform -chdir=terraform/envs/staging/app-service init",
    "tf:plan:staging:app-service": "terraform -chdir=terraform/envs/staging/app-service plan",
    "tf:apply:staging:app-service": "terraform -chdir=terraform/envs/staging/app-service apply",
    "tf:apply:staging:app-service:auto": "terraform -chdir=terraform/envs/staging/app-service apply -auto-approve",
    "docker:build:api": "docker build -f docker/api.Dockerfile -t deck-pack-api:local .",
    "docker:build:ops": "docker build -f docker/ops.Dockerfile -t deck-pack-ops:local .",
    "docker:build": "pnpm docker:build:api && pnpm docker:build:ops",
    "docker:run:api": "docker run --rm --name deck-pack-api-local -p 3000:3000 --env-file ${API_ENV_FILE:-apps/api/.env} deck-pack-api:local",
    "docker:run:ops": "docker run --rm --name deck-pack-ops-local -p 8080:8080 --env-file ${OPS_ENV_FILE:-apps/ops/.env} deck-pack-ops:local",
    "docker:run": "pnpm docker:run:api",
    "docker:stop:api": "docker stop deck-pack-api-local",
    "docker:stop:ops": "docker stop deck-pack-ops-local",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run --config vitest.unit.config.ts",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:integration:with-db": "pnpm db:start && pnpm test:integration",
    "check-types": "turbo check-types",
    "dev:api": "turbo -F @deck-pack/api dev",
    "dev:ops": "turbo -F @deck-pack/ops dev",
    "dev:portal": "turbo -F @deck-pack/portal dev",
    "dev:addin-one": "turbo -F @deck-pack/addin-one dev",
    "db:push": "turbo -F @deck-pack/db db:push",
    "db:studio": "turbo -F @deck-pack/db db:studio",
    "db:generate": "turbo -F @deck-pack/db db:generate",
    "db:migrate": "turbo -F @deck-pack/db db:migrate",
    "db:start": "turbo -F @deck-pack/db db:start",
    "db:watch": "turbo -F @deck-pack/db db:watch",
    "db:stop": "turbo -F @deck-pack/db db:stop",
    "db:down": "turbo -F @deck-pack/db db:down",
    "oxlint:strict": "oxlint --type-aware --type-check",
    "check": "pnpm oxlint:strict && oxfmt --write",
    "agent:install": "bash external/agent-stack/scripts/install-plugin.sh",
    "steno:ingest": "steno ingest",
    "steno:dev": "steno dev"
  },
  "dependencies": {
    "@deck-pack/env": "workspace:*",
    "dotenv": "catalog:",
    "superjson": "^2.2.6",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deck-pack/config": "workspace:*",
    "@joostwmd/steno": "^0.1.2",
    "@types/node": "catalog:",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.3",
    "lefthook": "^2.0.13",
    "oxfmt": "^0.26.0",
    "oxlint": "^1.41.0",
    "oxlint-tsgolint": "^0.21.1",
    "turbo": "^2.8.12",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@10.33.0"
}
