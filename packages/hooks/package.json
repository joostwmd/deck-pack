{
  "name": "@deck-pack/hooks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./gallery": {
      "default": "./src/gallery/index.ts"
    },
    "./gallery/*": {
      "default": "./src/gallery/*.ts"
    },
    "./organization": {
      "default": "./src/organization/index.ts"
    },
    "./organization/*": {
      "default": "./src/organization/*.ts"
    },
    "./users": {
      "default": "./src/users/index.ts"
    },
    "./users/*": {
      "default": "./src/users/*.ts"
    },
    "./billing": {
      "default": "./src/billing/index.ts"
    },
    "./billing/*": {
      "default": "./src/billing/*.ts"
    },
    "./members": {
      "default": "./src/members/index.ts"
    },
    "./members/*": {
      "default": "./src/members/*.ts"
    },
    "./seats": {
      "default": "./src/seats/index.ts"
    },
    "./seats/*": {
      "default": "./src/seats/*.ts"
    },
    "./usage": {
      "default": "./src/usage/index.ts"
    },
    "./usage/*": {
      "default": "./src/usage/*.ts"
    },
    "./brand-profiles": {
      "default": "./src/brand-profiles/index.ts"
    },
    "./brand-profiles/*": {
      "default": "./src/brand-profiles/*.ts"
    },
    "./shortcut-overrides": {
      "default": "./src/shortcut-overrides/index.ts"
    },
    "./shortcut-overrides/*": {
      "default": "./src/shortcut-overrides/*.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@deck-pack/brand-compliance": "workspace:*",
    "@deck-pack/db": "workspace:*",
    "@deck-pack/shortcuts": "workspace:*",
    "@tanstack/react-query": "^5.90.12",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@deck-pack/config": "workspace:*",
    "@types/react": "^19.2.10",
    "typescript": "catalog:"
  }
}
