{
  "extends": "@deck-pack/config/tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "paths": {
      "@deck-pack/ui/*": ["./src/*"],
      "@/*": ["../../apps/addins/assets/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "stories/**/*.ts", "stories/**/*.tsx"],
  "exclude": ["node_modules", ".storybook", "src/**/*.stories.tsx"]
}
