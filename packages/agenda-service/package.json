{
  "name": "@deck-pack/agenda-service",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./schemas": {
      "default": "./src/schemas.ts"
    },
    "./repositories/*": {
      "default": "./src/repositories/*.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "check-types": "tsc --noEmit"
  },
  "dependencies": {
    "@deck-pack/agenda": "workspace:*",
    "@deck-pack/db": "workspace:*",
    "@deck-pack/errors": "workspace:*",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deck-pack/config": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  }
}
