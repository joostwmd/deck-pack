{
  "name": "@deck-pack/db",
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./gallery-catalog": {
      "default": "./src/gallery-catalog.ts"
    },
    "./schema/*": {
      "default": "./src/schema/*.ts"
    },
    "./test-utils/*": {
      "default": "./src/test-utils/*.ts"
    },
    "./*": {
      "default": "./src/*.ts"
    }
  },
  "scripts": {
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "db:start": "docker compose up -d --wait",
    "db:watch": "docker compose up",
    "db:stop": "docker compose stop",
    "db:down": "docker compose down"
  },
  "dependencies": {
    "@deck-pack/env": "workspace:*",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.17.1",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deck-pack/agenda": "workspace:*",
    "@deck-pack/config": "workspace:*",
    "@electric-sql/pglite": "^0.5.4",
    "@types/pg": "^8.16.0",
    "drizzle-kit": "^0.31.8",
    "typescript": "catalog:"
  }
}
