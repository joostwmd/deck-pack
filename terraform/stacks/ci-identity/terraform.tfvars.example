# Copy to terraform.tfvars and fill with real values.
subscription_id  = "00000000-0000-0000-0000-000000000000"
tenant_id        = "00000000-0000-0000-0000-000000000000"

# Pull these from foundation stack outputs:
#   terraform -chdir=../foundation output -raw acr_id
#   terraform -chdir=../foundation output -raw acr_name
#   terraform -chdir=../foundation output -raw acr_login_server
acr_id           = "/subscriptions/00000000-0000-0000-0000-000000000000/resourceGroups/rg-deck-pack-cloud/providers/Microsoft.ContainerRegistry/registries/deckpackacr12345"
acr_name         = "deckpackacr12345"
acr_login_server = "deckpackacr12345.azurecr.io"

github_owner     = "your-github-owner"
github_repo      = "deck-pack"
github_branch    = "main"

identity_name    = "deck-pack-github-ci"

# Optional
# tags = {
#   project = "deck-pack"
#   managed = "terraform"
#   scope   = "ci-identity"
# }
