subscription_id = "00000000-0000-0000-0000-000000000000"

# Globally unique, lowercase, 3-63 chars. Becomes <server_name>.postgres.database.azure.com.
server_name = "deck-pack-db-<your-initials-or-suffix>"

# Optional — allow your current laptop IPv4 through the firewall for psql / drizzle-kit studio.
# Azure wants a plain IPv4 address (no CIDR, no port, no trailing %).
# Grab it safely with:  curl -s ifconfig.me | tr -d '[:space:]%'
# Leave unset to deny all non-Azure sources.
# developer_ip = "203.0.113.10"

# Optional overrides
# location              = "westeurope"
# resource_group_name   = "rg-deck-pack-cloud"
# postgres_version      = "16"
# sku_name              = "B_Standard_B1ms"
# storage_mb            = 32768
# backup_retention_days = 7
# admin_username        = "pgadmin"
# database_name         = "deck_pack"
