# Copy to apps/api/.env for local API + DB + auth (server-side secrets).
# Must match packages/db/docker-compose.yml (user postgres, password password, database deck-pack).
DATABASE_URL="postgresql://postgres:password@localhost:5432/deck-pack"
BETTER_AUTH_SECRET="replace-with-at-least-32-characters-secret-string"
BETTER_AUTH_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3001"
NODE_ENV="development"

# Resend: real API key + a verified "from" address (same in dev; no mail fallback). Server-only.
RESEND_API_KEY="re_xxxxxxxx"
EMAIL_FROM="auth@your-verified-domain.com"

# Optional: only emails ending with @<this> are sent an OTP and can sign in via ops.
OPS_SIGNUP_EMAIL_DOMAIN="code.berlin"

# Copy to apps/ops/.env, apps/portal/.env, apps/addins/assets/.env — URL of the API for browser requests.
# For the add-in dev server (HTTPS on :3003 with /api proxy), use https://localhost:3003
VITE_SERVER_URL="http://localhost:3000"

# CORS_ORIGINS must include every browser app origin (portal, ops, add-in), e.g.:
# CORS_ORIGINS="http://localhost:3001,https://localhost:3003"
