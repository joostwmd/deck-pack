# Copy to apps/api/.env for local API + DB + auth (server-side secrets).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/deck_pack"
BETTER_AUTH_SECRET="replace-with-at-least-32-characters-secret-string"
BETTER_AUTH_URL="http://localhost:3000"
CORS_ORIGINS="http://localhost:3001"
NODE_ENV="development"

# Copy to apps/ops/.env, apps/portal/.env, apps/addins/addin-one/.env — URL of the API for browser requests.
VITE_SERVER_URL="http://localhost:3000"
