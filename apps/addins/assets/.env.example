# In dev the add-in server is HTTPS (https://localhost:3003). The Vite proxy forwards
# /api/* to the local API, so point VITE_SERVER_URL at the add-in itself to avoid
# mixed-content errors (HTTPS page → HTTP API).
VITE_SERVER_URL="https://localhost:3003"

# Optional: browser Sentry DSN for client error reporting.
# VITE_SENTRY_DSN="https://examplePublicKey@o0.ingest.sentry.io/0"

# Microsoft Entra application (client) ID for Office NAA. Must match API MICROSOFT_CLIENT_ID.
# VITE_MICROSOFT_CLIENT_ID="your-entra-client-id"
