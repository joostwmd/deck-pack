{
  "name": "@deck-pack/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./context": "./src/trpc/context.ts",
    "./routers/index": "./src/trpc/router.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@deck-pack/agenda": "workspace:*",
    "@deck-pack/auth": "workspace:*",
    "@deck-pack/db": "workspace:*",
    "@deck-pack/env": "workspace:*",
    "@deck-pack/errors": "workspace:*",
    "@deck-pack/integrations": "workspace:*",
    "@deck-pack/organization": "workspace:*",
    "@deck-pack/presentation-check": "workspace:*",
    "@deck-pack/seats": "workspace:*",
    "@deck-pack/shortcuts": "workspace:*",
    "@deck-pack/storage": "workspace:*",
    "@deck-pack/users": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "@hono/trpc-server": "^0.4.0",
    "@hono/zod-validator": "^0.8.0",
    "@logtape/drizzle-orm": "^2.0.5",
    "@logtape/file": "^2.0.5",
    "@logtape/hono": "^2.0.5",
    "@logtape/logtape": "^2.0.5",
    "@logtape/sentry": "^2.0.5",
    "@sentry/node": "^10.51.0",
    "@trpc/server": "catalog:",
    "apitally": "^0.25.6",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "hono": "catalog:",
    "superjson": "^2.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-auth/utils": "^0.3.1",
    "@deck-pack/config": "workspace:*",
    "@types/node": "catalog:",
    "better-call": "^1.3.2",
    "tsdown": "^0.16.5",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
