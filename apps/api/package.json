{
  "name": "@deck-pack/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./context": "./src/context.ts",
    "./routers/index": "./src/routers/index.ts",
    "./*": "./src/*.ts"
  },
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@deck-pack/auth": "workspace:*",
    "@deck-pack/db": "workspace:*",
    "@deck-pack/env": "workspace:*",
    "@hono/node-server": "^1.14.4",
    "@hono/trpc-server": "^0.4.0",
    "@trpc/server": "catalog:",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@deck-pack/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.16.5",
    "tsx": "^4.19.2",
    "typescript": "catalog:"
  }
}
