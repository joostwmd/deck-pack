# HTTP port (defaults to 3000 if unset; Azure App Service sets PORT)
# PORT=3000
# Note: this file uses quoted values for dotenv.
# Docker --env-file reads quotes literally, so use apps/api/.env.docker.example for container runs.

DATABASE_URL=postgresql://postgres:password@localhost:5432/deck-pack
BETTER_AUTH_SECRET=replace-with-at-least-32-characters-secret-string
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,https://localhost:3003
OPS_ORIGINS=http://localhost:3001
OPS_SIGNUP_EMAIL_DOMAIN=code.berlin
NODE_ENV=development

# Resend (required for OTP / mail; verified domain in Resend)
EMAIL_API_KEY=re_your_resend_api_key
EMAIL_FROM=auth@your-verified-domain.com

# Pexels stock photo search (required for Images tab in assets add-in)
PEXELS_API_KEY=your_pexels_api_key

# Optional observability (omit to disable)
# SENTRY_DSN=
# APITALLY_CLIENT_ID=
# APITALLY_ENV=dev

# Optional Microsoft OAuth for app auth (portal, add-in). Both required to enable.
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
#
# Add-in builds also need the public client id when Office NAA is enabled:
# VITE_MICROSOFT_CLIENT_ID=<same value as MICROSOFT_CLIENT_ID>
