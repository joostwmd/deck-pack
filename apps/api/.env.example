# HTTP port (defaults to 3000 if unset; Azure App Service sets PORT)
# PORT=3000
# Note: this file uses quoted values for dotenv.
# Docker --env-file reads quotes literally, so use apps/api/.env.docker.example for container runs.

DATABASE_URL=postgresql://postgres:password@localhost:5432/deck-pack
BETTER_AUTH_SECRET=replace-with-at-least-32-characters-secret-string
BETTER_AUTH_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001
NODE_ENV=development

# Optional observability (omit to disable)
# SENTRY_DSN=
# APITALLY_CLIENT_ID=
# APITALLY_ENV=dev
